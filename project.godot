; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="ProjectMarsHighFidelity"
run/main_scene="res://scenes/opening_intro.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")

[audio]

general/text_to_speech=true
driver/enable_input=true

[autoload]

EventBus="*res://scripts/event_bus.gd"
GameState="*res://scripts/game_state.gd"
RuntimeFeatures="*res://scripts/runtime_features.gd"
AirPodsHeadTracker="*res://scripts/airpods_head_tracker.gd"
VoiceAlertService="*res://scripts/voice_alert_service.gd"
MonetizationService="*res://scripts/monetization_service.gd"
CommandServer="*res://scripts/command_server.gd"
SudoAIAgent="*res://scripts/sudo_ai_agent.gd"

[display]

window/size/viewport_width=2360
window/size/viewport_height=1640
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[input_devices]

pointing/emulate_touch_from_mouse=true

[rendering]

renderer/rendering_method="forward_plus"
textures/vram_compression/import_etc2_astc=true
anti_aliasing/quality/msaa_3d=2
anti_aliasing/quality/screen_space_aa=1

[sudo_ai]

ios_bridge_base_url="http://zs-Mac-mini.local:8765"
